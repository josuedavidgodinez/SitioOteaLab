---
import Layout from '../layouts/Layout.astro';
import { BUSINESS, STATS } from '../config/business';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('es');

const values = [
  {
    icon: "M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z",
    title: "Visión estratégica",
    description: "Entendemos tu negocio antes de escribir una línea de código. La tecnología es el medio, no el fin.",
  },
  {
    icon: "M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z",
    title: "Calidad sin negociar",
    description: "Código limpio, documentado y probado. Entregamos soluciones que duran, no parches que se rompen.",
  },
  {
    icon: "M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z",
    title: "Comunicación clara",
    description: "Sin tecnicismos innecesarios. Te mantenemos informado en cada etapa con reportes y demos reales.",
  },
  {
    icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z",
    title: "Entregas que escalan",
    description: "Arquitecturas pensadas para crecer contigo. Lo que construimos hoy no te limita mañana.",
  },
];

const techStack = [
  { category: "Frontend", items: ["React", "Angular", "TypeScript", "Ionic"] },
  { category: "Mobile", items: ["React Native", "Ionic"] },
  { category: "Backend", items: ["Node.js", "PHP", ".NET"] },
  { category: "Cloud", items: ["GCP", "Cloud Functions", "BigQuery", "Pub/Sub"] },
  { category: "Bases de datos", items: ["SQL Server", "MySQL", "MongoDB", "Redis"] },
  { category: "Automatización", items: ["Zapier", "Pabbly", "Make", "WordPress"] },
];

const journey = [
  {
    period: "2019 – 2022",
    title: "Los primeros años",
    description: "Primeros pasos en desarrollo profesional en la Universidad Rafael Landívar y Banco Agromercantil, construyendo bases sólidas en SQL, .NET y automatización de procesos.",
  },
  {
    period: "2022 – 2023",
    title: "Crecimiento en fintech",
    description: "Ingreso a Allied Global Technology Services como Software Engineer Mid-Level, construyendo soluciones fintech con Ionic, React Native, Angular y Node.js.",
  },
  {
    period: "2023 – Presente",
    title: "Liderazgo e internacionalización",
    description: "Ascenso a Engineering Tech Lead. Inicio de proyectos freelance con clientes en España y EE.UU. Maestría en Transformación Digital. Fundación de Otea Lab.",
  },
];
---

<Layout title={t.about.sectionTitle}>

  <!-- ── Hero empresa ────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-primary-deep via-primary to-primary-dark text-white py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4">
        {t.about.sectionTitle}
      </p>
      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold mb-6 leading-tight">
        {t.about.headline}
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        {t.about.bio}
      </p>
    </div>
  </section>

  <!-- ── Stats ─────────────────────────────────────────────────────── -->
  <section class="border-b border-border bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: STATS.yearsExperience,   label: t.about.yearsExperience },
          { value: STATS.projectsDelivered, label: t.about.projectsCompleted },
          { value: STATS.clientsServed,     label: t.about.clientsServed },
          { value: STATS.countries,         label: t.about.countriesWorked },
        ].map(({ value, label }) => (
          <div>
            <dt class="text-3xl font-extrabold text-primary">{value}</dt>
            <dd class="text-sm text-neutral mt-1">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ── Valores / Enfoque ──────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-2">
        {t.about.valuesTitle}
      </p>
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-dark">
        Por qué trabajar con Otea Lab
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((v) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-accent-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={v.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-dark text-base mb-2">{v.title}</h3>
          <p class="text-sm text-neutral leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Nuestro recorrido + Capacidades ───────────────────────────── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16">




    <!-- Tech capabilities -->
    <div>
      <h2 class="text-2xl font-heading font-extrabold text-dark mb-8">
        {t.about.skills}
      </h2>
      <div class="space-y-6">
        {techStack.map(({ category, items }) => (
          <div>
            <p class="text-xs font-bold text-neutral uppercase tracking-widest mb-2.5">
              {category}
            </p>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-sm font-medium bg-surface border border-border text-dark px-3 py-1.5 rounded-full hover:border-primary/40 hover:text-primary transition-colors">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-10 bg-primary-deep rounded-2xl p-6 text-white text-center">
        <p class="font-heading font-bold text-lg mb-2">¿Listo para trabajar juntos?</p>
        <p class="text-white/70 text-sm mb-5">Cuéntanos tu proyecto y armamos una propuesta a tu medida.</p>
        <a
          href="/contacto"
          class="inline-flex items-center bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm"
        >
          {t.nav.cta}
        </a>
      </div>
    </div>

  </section>

</Layout>
