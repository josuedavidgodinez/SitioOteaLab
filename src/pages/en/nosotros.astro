---
import Layout from '../../layouts/Layout.astro';
import { BUSINESS, STATS } from '../../config/business';
import { useTranslations } from '../../i18n/utils';
import { values, journey, education, techStack } from '../../data/about';

const t = useTranslations('en');
const lang = 'en';
---

<Layout title={t.about.sectionTitle}>

  <section class="bg-gradient-to-br from-primary-deep via-primary to-primary-dark text-white py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4">{t.about.sectionTitle}</p>
      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold mb-6 leading-tight">{t.about.headline}</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">{t.about.bio}</p>
    </div>
  </section>

  <section class="border-b border-border bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: STATS.yearsExperience,   label: t.about.yearsExperience },
          { value: STATS.projectsDelivered, label: t.about.projectsCompleted },
          { value: STATS.clientsServed,     label: t.about.clientsServed },
          { value: STATS.countries,         label: t.about.countriesWorked },
        ].map(({ value, label }) => (
          <div>
            <dt class="text-3xl font-extrabold text-primary">{value}</dt>
            <dd class="text-sm text-neutral mt-1">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-2">{t.about.valuesTitle}</p>
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-dark">{t.aboutPage.whyUs}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((v) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-accent-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={v.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-dark text-base mb-2">{v.title[lang]}</h3>
          <p class="text-sm text-neutral leading-relaxed">{v.description[lang]}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Team -->
  <section class="bg-background border-y border-border py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-2">{t.aboutPage.teamLabel}</p>
        <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-dark">{t.about.teamTitle}</h2>
      </div>
      <div class="max-w-sm mx-auto">
        <div class="bg-surface border border-border rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
          <div class="h-64 bg-gradient-to-br from-primary-deep to-primary overflow-hidden">
            <img src="/assets/josue.jpeg" alt="Josué Godínez — CEO & Tech Lead" class="w-full h-full  object-contain bg-background " loading="lazy" />
          </div>
          <div class="p-6 text-center">
            <span class="inline-block text-xs font-bold text-accent bg-accent-light px-3 py-1 rounded-full mb-3 uppercase tracking-wider">
              {t.aboutPage.ceoTitle}
            </span>
            <h3 class="font-heading font-extrabold text-dark text-xl mb-1">Josué Godínez</h3>
            <p class="text-sm text-neutral mb-1">{t.aboutPage.ceoCredentials}</p>
            <p class="text-xs text-neutral/70 mb-5">{BUSINESS.contact.location.city}, {BUSINESS.contact.location.country}</p>
            <p class="text-sm text-neutral leading-relaxed mb-6">{t.aboutPage.ceoBio}</p>
            <div class="flex justify-center gap-3">
              <a href={BUSINESS.social.linkedin} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-dark border border-border rounded-lg px-4 py-2 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                LinkedIn
              </a>
              <a href={BUSINESS.social.github} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-sm font-semibold text-neutral hover:text-dark border border-border rounded-lg px-4 py-2 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Journey + Capabilities -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16">


    <div>
      <h2 class="text-2xl font-heading font-extrabold text-dark mb-8">{t.about.skills}</h2>
      <div class="space-y-6">
        {techStack.map(({ category, items }) => (
          <div>
            <p class="text-xs font-bold text-neutral uppercase tracking-widest mb-2.5">{category[lang]}</p>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-sm font-medium bg-surface border border-border text-dark px-3 py-1.5 rounded-full hover:border-primary/40 hover:text-primary transition-colors">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 bg-primary-deep rounded-2xl p-6 text-white text-center">
        <p class="font-heading font-bold text-lg mb-2">{t.aboutPage.ctaTitle}</p>
        <p class="text-white/70 text-sm mb-5">{t.aboutPage.ctaDesc}</p>
        <a href="/en/contacto" class="inline-flex items-center bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">
          {t.nav.cta}
        </a>
      </div>
    </div>
  </section>

</Layout>
