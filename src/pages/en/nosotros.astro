---
import Layout from '../../layouts/Layout.astro';
import { BUSINESS, STATS } from '../../config/business';
import { useTranslations } from '../../i18n/utils';
import { values, journey, education, techStack } from '../../data/about';

const t = useTranslations('en');
const lang = 'en';
---

<Layout title={t.about.sectionTitle}>

  <section class="bg-gradient-to-br from-primary-deep via-primary to-primary-dark text-white py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4">{t.about.sectionTitle}</p>
      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold mb-6 leading-tight">{t.about.headline}</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">{t.about.bio}</p>
    </div>
  </section>

  <section class="border-b border-border bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: STATS.yearsExperience,   label: t.about.yearsExperience },
          { value: STATS.projectsDelivered, label: t.about.projectsCompleted },
          { value: STATS.clientsServed,     label: t.about.clientsServed },
          { value: STATS.countries,         label: t.about.countriesWorked },
        ].map(({ value, label }) => (
          <div>
            <dt class="text-3xl font-extrabold text-primary">{value}</dt>
            <dd class="text-sm text-neutral mt-1">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-2">{t.about.valuesTitle}</p>
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-dark">{t.aboutPage.whyUs}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map((v) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="w-11 h-11 rounded-xl bg-accent-light flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={v.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-dark text-base mb-2">{v.title[lang]}</h3>
          <p class="text-sm text-neutral leading-relaxed">{v.description[lang]}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Journey + Capabilities -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16">


    <div>
      <h2 class="text-2xl font-heading font-extrabold text-dark mb-8">{t.about.skills}</h2>
      <div class="space-y-6">
        {techStack.map(({ category, items }) => (
          <div>
            <p class="text-xs font-bold text-neutral uppercase tracking-widest mb-2.5">{category[lang]}</p>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="text-sm font-medium bg-surface border border-border text-dark px-3 py-1.5 rounded-full hover:border-primary/40 hover:text-primary transition-colors">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 bg-primary-deep rounded-2xl p-6 text-white text-center">
        <p class="font-heading font-bold text-lg mb-2">{t.aboutPage.ctaTitle}</p>
        <p class="text-white/70 text-sm mb-5">{t.aboutPage.ctaDesc}</p>
        <a href="/en/contacto" class="inline-flex items-center bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">
          {t.nav.cta}
        </a>
      </div>
    </div>
  </section>

</Layout>
