---
/**
 * Header.astro — Site-wide navigation bar.
 */
import { BUSINESS, NAV_LINKS } from "../config/business";
import { useTranslations, getAlternatePath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url);
const alternateLang = lang === "es" ? "EN" : "ES";
---

<header
  class="sticky top-0 z-50 bg-surface/90 backdrop-blur border-b border-border"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav
      class="flex items-center justify-between h-40"
      aria-label="Navegación principal"
    >
      <!-- Logo + Name -->
      <a
        href={lang === "es" ? "/" : "/en"}
        class=""
      >
        <div class="grid grid-cols-24">
          <div class="col-span-12  hidden sm:block">
            <img
              src={BUSINESS.logo}
              alt={`${BUSINESS.name} logo`}
              class="h-30 w-auto"
            />
          </div>
          <div class="col-span-12 sm:col-span-24 flex items-center">
            <img
              src={BUSINESS.logoText}
              alt={`${BUSINESS.name} logotype`}
              class="h-30 w-auto"
            />
          </div>
        </div>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-1">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={lang === "en" ? `/en${link.href}` : link.href}
                class="px-3 py-2 text-sm font-medium text-neutral hover:text-primary rounded-md transition-colors"
              >
                {link.label[lang]}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Right side: lang switcher + CTA -->
      <div class="flex items-center gap-3">
        <!-- Language switcher -->
        <a
          href={alternatePath}
          class="hidden lg:inline-flex items-center gap-1 text-xs font-semibold text-neutral hover:text-primary border border-border rounded-full px-3 py-1 transition-colors"
          aria-label={`Switch to ${alternateLang}`}
        >
          {alternateLang}
        </a>

        <!-- CTA button -->
        <a
          href={lang === "en" ? "/en/contacto" : "/contacto"}
          class="hidden lg:inline-flex items-center bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
        >
          {t.nav.cta}
        </a>

        <!-- Mobile menu button (placeholder — wire up in Fase 2) -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 rounded-md text-neutral hover:text-primary"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu (hidden by default) -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-border mt-0 pt-3"
    >
      <ul class="flex flex-col gap-1">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={lang === "en" ? `/en${link.href}` : link.href}
                class="block px-3 py-2 text-sm font-medium text-neutral hover:text-primary rounded-md transition-colors"
              >
                {link.label[lang]}
              </a>
            </li>
          ))
        }
        <li class="mt-2 pt-2 border-t border-border">
          <a
            href={lang === "en" ? "/en/contacto" : "/contacto"}
            class="block px-3 py-2 text-sm font-semibold text-primary"
          >
            {t.nav.cta}
          </a>
        </li>
        <li>
          <a href={alternatePath} class="block px-3 py-2 text-sm text-neutral">
            Ver en {alternateLang}
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>
