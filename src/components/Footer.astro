---
/**
 * Footer.astro — Site-wide footer.
 */
import { BUSINESS, NAV_LINKS } from '../config/business';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-deep text-white mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand column -->
      <div class="flex flex-col gap-4">
        <a href={lang === 'es' ? '/' : '/en'} class="flex items-center gap-2.5 w-fit">
          <img
            src={BUSINESS.logo}
            alt={`${BUSINESS.name} logo`}
            width="28"
            height="34"
            class="h-7 w-auto brightness-0 invert"
          />
          <span class="font-heading font-bold text-lg tracking-tight">
            {BUSINESS.name}
          </span>
        </a>
        <p class="text-sm text-accent-light/70 leading-relaxed max-w-xs">
          {t.site.tagline}
        </p>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">
          {lang === 'es' ? 'Navegación' : 'Navigation'}
        </h3>
        <ul class="flex flex-col gap-2">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={lang === 'en' ? `/en${link.href}` : link.href}
                class="text-sm text-white/70 hover:text-white transition-colors"
              >
                {link.label[lang]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50 mb-4">
          {lang === 'es' ? 'Contacto' : 'Contact'}
        </h3>
        <ul class="flex flex-col gap-2">
          <li>
            <a
              href={`mailto:${BUSINESS.contact.email}`}
              class="text-sm text-white/70 hover:text-white transition-colors"
            >
              {BUSINESS.contact.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${BUSINESS.contact.phone.replace(/\s/g, '')}`}
              class="text-sm text-white/70 hover:text-white transition-colors"
            >
              {BUSINESS.contact.phone}
            </a>
          </li>
          <li class="text-sm text-white/50 mt-1">
            {BUSINESS.contact.location.city}, {BUSINESS.contact.location.country}
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
      <span>
        © {currentYear} {BUSINESS.name}. {t.footer.rights}
      </span>
    </div>
  </div>
</footer>
