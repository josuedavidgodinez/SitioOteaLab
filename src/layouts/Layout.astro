---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { BUSINESS } from '../config/business';
import { getLang, getAlternatePath } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const lang = getLang(Astro.url);

const pageTitle = title
  ? `${title} | ${BUSINESS.name}`
  : BUSINESS.seo.defaultTitle[lang];

const pageDescription = description ?? BUSINESS.seo.defaultDescription[lang];
const pageOgImage = ogImage ?? BUSINESS.seo.ogImage;
const canonicalURL = new URL(Astro.url.pathname, BUSINESS.url);

// hreflang: current, alternate, and x-default (always points to ES root)
const alternatePath = getAlternatePath(Astro.url);
const alternateURL = new URL(alternatePath, BUSINESS.url);
const alternateLang = lang === 'es' ? 'en' : 'es';
const xDefaultURL = lang === 'es' ? canonicalURL : alternateURL;

// JSON-LD — Organization + WebSite (valid on every page)
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${BUSINESS.url}/#organization`,
      name: BUSINESS.name,
      url: BUSINESS.url,
      logo: {
        '@type': 'ImageObject',
        url: new URL(BUSINESS.logo, BUSINESS.url).href,
      },
      image: new URL(BUSINESS.seo.ogImage, BUSINESS.url).href,
      description: BUSINESS.seo.defaultDescription[lang],
      telephone: BUSINESS.contact.phone,
      email: BUSINESS.contact.email,
      address: {
        '@type': 'PostalAddress',
        addressLocality: BUSINESS.contact.location.city,
        addressCountry: BUSINESS.contact.location.countryCode,
      },
      sameAs: [],
      areaServed: [
        { '@type': 'Country', name: 'Guatemala' },
        { '@type': 'Country', name: 'Spain' },
        { '@type': 'Country', name: 'United States' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${BUSINESS.url}/#website`,
      name: BUSINESS.name,
      url: BUSINESS.url,
      publisher: { '@id': `${BUSINESS.url}/#organization` },
      inLanguage: ['es-GT', 'en-US'],
    },
  ],
};

const waPhone = BUSINESS.contact.phone.replace(/\s|\+/g, '');
const waMessage = lang === 'en'
  ? "Hi! I'm interested in learning more about your software services."
  : 'Hola, me interesa conocer más sobre sus servicios de software.';
const waUrl = `https://wa.me/${waPhone}?text=${encodeURIComponent(waMessage)}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={BUSINESS.seo.keywords[lang].join(', ')} />
    <meta name="author" content={BUSINESS.legalName} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="theme-color" content="#00A090" />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang — bilingual alternates -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link rel="alternate" hreflang="x-default" href={xDefaultURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL(pageOgImage, BUSINESS.url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:locale" content={lang === 'es' ? 'es_GT' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_GT'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(pageOgImage, BUSINESS.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={BUSINESS.favicon} />

    <!-- Font preload for LCP performance -->
    <link
      rel="preload"
      href="/assets/fonts/Outfit-VariableFont_wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- WhatsApp floating button -->
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === 'en' ? 'Contact via WhatsApp' : 'Contactar por WhatsApp'}
      class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] hover:bg-[#1ebe57] rounded-full shadow-lg transition-transform hover:scale-110"
    >
      <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>
  </body>
</html>
